{
  "agent_id": "visual-production-agent",
  "name": "Cinematic Visual Studio",
  "version": "1.0.0",
  "engines": {
    "video": {
      "model_name": "veo-3.1-generate-video",
      "resolution": "4k",
      "aspect_ratios_supported": ["16:9", "9:16", "1:1"],
      "default_duration_seconds": 6,
      "audio": {
        "sync_native_audio": true,
        "default_voice_gender": "neutral",
        "audio_sample_rate_hz": 48000
      }
    },
    "image": {
      "model_name": "imagen-3",
      "resolution": "high",
      "formats": ["jpeg", "png"]
    }
  },
  "asset_mapping": {
    "allow_logo_watermark": true,
    "logo_position": "top_right",
    "persona_placement": "center"
  }
}
