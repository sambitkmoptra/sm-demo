{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SafetyAuditPayload",
  "type": "object",
  "properties": {
    "campaign_id": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "audit_results": {
      "type": "object",
      "properties": {
        "is_safe": {
          "type": "boolean"
        },
        "safety_score": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "violations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "rule_id": { "type": "string" },
              "severity": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"] },
              "message": { "type": "string" },
              "violating_snippet": { "type": "string" }
            },
            "required": ["rule_id", "severity", "message"]
          }
        }
      },
      "required": ["is_safe", "safety_score", "violations"]
    },
    "checked_contents": {
      "type": "object",
      "properties": {
        "text_outputs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "field": { "type": "string" },
              "content": { "type": "string" },
              "grounded_sources": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "required": ["field", "content"]
          }
        },
        "media_outputs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "asset_id": { "type": "string" },
              "gcs_uri": { "type": "string" },
              "mime_type": { "type": "string" },
              "duration_seconds": { "type": "number" }
            },
            "required": ["asset_id", "gcs_uri", "mime_type"]
          }
        }
      },
      "required": ["text_outputs", "media_outputs"]
    }
  },
  "required": ["campaign_id", "timestamp", "audit_results", "checked_contents"]
}
